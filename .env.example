# =============================================================================
# GSF Demo — Snowflake Credentials
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit credentials.
#
# SNOWFLAKE_ACCOUNT: your account identifier (not the full URL).
#
#   Business Critical / Enterprise accounts use org-based format:
#     <orgname>-<account_name>    e.g.  myorg-myaccount
#
#   To find your values, run in a Snowflake worksheet:
#     SELECT CURRENT_ORGANIZATION_NAME(), CURRENT_ACCOUNT_NAME();
#   Then combine: <org>-<account>  (both lowercase, hyphen-separated)
#
#   Alternative: Snowflake UI → Admin → Accounts → copy the "Account" column.
#   The locator-based format (<locator>.us-east-1.aws) also works but is legacy.
# =============================================================================

SNOWFLAKE_ACCOUNT=<orgname>-<accountname>
SNOWFLAKE_USER=<your_username>

# --- Authentication: choose ONE of the two methods below ---

# Method 1 (recommended): Key-pair auth — bypasses MFA for programmatic access.
# Generate keys:
#   openssl genrsa 2048 | openssl pkcs8 -topk8 -nocrypt -outform DER -out snowflake_rsa_key.p8
#   openssl rsa -inform DER -in snowflake_rsa_key.p8 -pubout -outform PEM -out snowflake_rsa_key.pub
# Register the public key in Snowflake (paste .pub contents without header/footer lines):
#   ALTER USER <your_username> SET RSA_PUBLIC_KEY='<public_key_contents>';
SNOWFLAKE_PRIVATE_KEY_FILE=snowflake_rsa_key.p8

# Method 2 (fallback): Password auth — will trigger Duo MFA push if MFA is enabled.
# SNOWFLAKE_PASSWORD=<your_password>

# Optional overrides — defaults match the GSF naming conventions
SNOWFLAKE_ROLE=GSF_ROLE
SNOWFLAKE_WAREHOUSE=GSF_WH
SNOWFLAKE_DATABASE=GSF_DEMO
